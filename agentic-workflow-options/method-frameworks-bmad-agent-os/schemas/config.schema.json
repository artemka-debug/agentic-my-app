{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/agentic/config.schema.json",
  "title": "Agentic workflow config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow",
    "approval",
    "github",
    "worktrees",
    "verification",
    "security",
    "traceability",
    "agents",
    "retry"
  ],
  "properties": {
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "local_only",
        "default_source",
        "default_depth",
        "candidate_strategy",
        "max_parallel_candidates"
      ],
      "properties": {
        "local_only": { "type": "boolean" },
        "default_source": {
          "type": "string",
          "enum": ["github", "plain_text", "linear", "notion", "jira"]
        },
        "default_depth": {
          "type": "string",
          "enum": ["quick", "standard", "full"]
        },
        "candidate_strategy": {
          "type": "string",
          "enum": ["competitive", "partitioned", "hybrid"]
        },
        "max_parallel_candidates": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        }
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_after_decomposition",
        "required_before_pr",
        "allow_autorun_for_low_risk",
        "max_autonomy_risk"
      ],
      "properties": {
        "required_after_decomposition": { "type": "boolean" },
        "required_before_pr": { "type": "boolean" },
        "allow_autorun_for_low_risk": { "type": "boolean" },
        "max_autonomy_risk": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        }
      }
    },
    "github": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "default_base_branch",
        "branch_prefix",
        "pr_draft_by_default",
        "link_issue",
        "monitor_after_open",
        "monitor_interval_seconds"
      ],
      "properties": {
        "default_base_branch": { "type": "string", "minLength": 1 },
        "branch_prefix": { "type": "string", "minLength": 1 },
        "pr_draft_by_default": { "type": "boolean" },
        "link_issue": { "type": "boolean" },
        "monitor_after_open": { "type": "boolean" },
        "monitor_interval_seconds": { "type": "integer", "minimum": 30 }
      }
    },
    "worktrees": {
      "type": "object",
      "additionalProperties": false,
      "required": ["root", "cleanup_on_success", "cleanup_on_failure"],
      "properties": {
        "root": { "type": "string", "minLength": 1 },
        "cleanup_on_success": { "type": "boolean" },
        "cleanup_on_failure": { "type": "boolean" }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "optional", "commands"],
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string" }
        },"optional": {
          "type": "array",
          "items": { "type": "string" }
        },
        "commands": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity_blocking", "check_dependencies", "check_secrets"],
      "properties": {
        "severity_blocking": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          }
        },
        "check_dependencies": { "type": "boolean" },
        "check_secrets": { "type": "boolean" }
      }
    },
    "traceability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "require_requirement_ids",
        "require_test_mapping",
        "require_po_acceptance"
      ],
      "properties": {
        "require_requirement_ids": { "type": "boolean" },
        "require_test_mapping": { "type": "boolean" },
        "require_po_acceptance": { "type": "boolean" }
      }
    },
    "agents": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "po",
        "spec",
        "decomposition",
        "implementation",
        "verifier"
      ],
      "properties": {
        "po": {
          "type": "object",
          "additionalProperties": false,
          "required": ["framework"],
          "properties": {
            "framework": { "type": "string" }
          }
        },
        "spec": {
          "type": "object",
          "additionalProperties": false,
          "required": ["framework"],
          "properties": {
            "framework": { "type": "string" }
          }
        },
        "decomposition": {
          "type": "object",
          "additionalProperties": false,
          "required": ["framework"],
          "properties": {
            "framework": { "type": "string" }
          }
        },
        "implementation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["count"],
          "properties": {
            "count": {
              "oneOf": [
                { "type": "integer", "minimum": 1 },
                { "type": "string", "const": "auto" }
              ]
            }
          }
        },
        "verifier": {
          "type": "object",
          "additionalProperties": false,
          "required": ["require_independent_context"],
          "properties": {
            "require_independent_context": { "type": "boolean" }
          }
        }
      }
    },
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_candidate_retries",
        "max_verification_loops",
        "max_pr_comment_fix_loops",
        "stop_on_security_high",
        "stop_on_unresolved_po_failure"
      ],
      "properties": {
        "max_candidate_retries": { "type": "integer", "minimum": 0 },
        "max_verification_loops": { "type": "integer", "minimum": 0 },
        "max_pr_comment_fix_loops": { "type": "integer", "minimum": 0 },
        "stop_on_security_high": { "type": "boolean" },
        "stop_on_unresolved_po_failure": { "type": "boolean" }
      }
    }
  }
}
